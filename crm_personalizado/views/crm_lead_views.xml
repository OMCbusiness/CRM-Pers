<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         FORMULARIO PRINCIPAL DE OPORTUNIDAD / LEAD
    ============================================================ -->
    <record id="crm_lead_form_view_custom" model="ir.ui.view">
        <field name="name">crm.lead.form.custom</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <!-- ── Ocultar campos del formulario original ── -->
            <field name="expected_revenue" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <field name="probability" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <field name="automated_probability" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <field name="user_id" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <field name="partner_id" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <field name="contact_name" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <field name="date_deadline" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <field name="tag_ids" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <field name="priority" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>

            <!-- ── Ocultar labels del original ── -->
            <label for="expected_revenue" position="attributes">
                <attribute name="invisible">1</attribute>
            </label>
            <label for="date_deadline" position="attributes">
                <attribute name="invisible">1</attribute>
            </label>
            <label for="probability" position="attributes">
                <attribute name="invisible">1</attribute>
            </label>

            <!-- ── Ocultar pestañas ── -->
            <page name="internal_notes" position="attributes">
                <attribute name="invisible">1</attribute>
            </page>
            <page name="lead" position="attributes">
                <attribute name="invisible">1</attribute>
            </page>
            <page name="extra" position="attributes">
                <attribute name="invisible">1</attribute>
            </page>

            <!-- ── Campos personalizados después del nombre ── -->
            <field name="name" position="after">
                <div class="crm-custom-header-block">

                    <!-- Fila 1: Email + Teléfono -->
                    <div class="crm-custom-row">
                        <div class="crm-custom-field-group crm-field-wide">
                            <label class="crm-custom-label" for="email_from">Correo electrónico</label>
                            <field name="email_from" widget="email" placeholder="correo@ejemplo.com"/>
                        </div>
                        <div class="crm-custom-field-group crm-field-wide">
                            <label class="crm-custom-label" for="phone">Teléfono</label>
                            <field name="phone" widget="phone" placeholder="+34 600 000 000"/>
                        </div>
                    </div>

                    <!-- Fila 2: Presupuesto + Operación -->
                    <div class="crm-custom-row">
                        <div class="crm-custom-field-group crm-field-wide">
                            <label class="crm-custom-label" for="budget">Presupuesto</label>
                            <field name="company_currency" invisible="1"/>
                            <field name="budget" widget="monetary" options="{'currency_field': 'company_currency'}"/>
                        </div>
                        <div class="crm-custom-field-group">
                            <label class="crm-custom-label" for="operation_type">Operación</label>
                            <field name="operation_type"
                                   widget="radio"
                                   options="{'horizontal': true}"
                                   class="crm-operation-radio"/>
                        </div>
                    </div>

                    <!-- Fila 3: Urgencia + Exclusiva -->
                    <div class="crm-custom-row">
                        <div class="crm-custom-field-group">
                            <label class="crm-custom-label" for="urgency_level">Nivel de urgencia</label>
                            <field name="urgency_level" widget="urgency_stars" class="crm-urgency-stars"/>
                        </div>
                        <div class="crm-custom-field-group crm-badge-group">
                            <field name="exclusive" widget="boolean_toggle" class="crm-exclusive-toggle"/>
                            <label class="crm-custom-label crm-label-inline" for="exclusive">Exclusiva</label>
                        </div>
                    </div>

                </div>
            </field>

        </field>
    </record>


    <!-- ============================================================
         VISTA KANBAN
    ============================================================ -->
    <record id="crm_lead_kanban_view_custom" model="ir.ui.view">
        <field name="name">crm.lead.kanban.custom</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_kanban_view_leads"/>
        <field name="arch" type="xml">

            <!-- Inyectar campos custom -->
            <templates position="before">
                <field name="urgency_level"/>
                <field name="operation_type"/>
                <field name="exclusive"/>
                <field name="budget"/>
                <field name="company_currency"/>
                <field name="email_from"/>
                <field name="phone"/>
            </templates>

            <!-- Reemplazar tarjeta completa -->
            <xpath expr="//t[@t-name='card']" position="replace">
                <t t-name="card">
                    <div t-attf-class="crm-card-urgency crm-card-level-#{record.urgency_level.raw_value || 0}">

                        <!-- Nombre -->
                        <field name="name" class="fw-bold fs-5"/>

                        <!-- Email -->
                        <div class="crm-card-field" t-if="record.email_from.raw_value">
                            <i class="fa fa-envelope crm-card-icon"/>
                            <field name="email_from" widget="email"/>
                        </div>

                        <!-- Teléfono -->
                        <div class="crm-card-field" t-if="record.phone.raw_value">
                            <i class="fa fa-phone crm-card-icon"/>
                            <field name="phone" widget="phone"/>
                        </div>

                        <!-- Presupuesto -->
                        <div class="crm-card-field" t-if="record.budget.raw_value">
                            <i class="fa fa-money crm-card-icon"/>
                            <field name="budget" widget="monetary" options="{'currency_field': 'company_currency'}"/>
                        </div>

                        <!-- Badges: Operación + Exclusiva -->
                        <div class="crm-kanban-badges">
                            <span t-if="record.operation_type.raw_value == 'sale'"
                                  class="crm-badge crm-badge-sale"><i class="fa fa-home me-1"/>Venta</span>
                            <span t-if="record.operation_type.raw_value == 'rent'"
                                  class="crm-badge crm-badge-rent"><i class="fa fa-key me-1"/>Alquiler</span>
                            <span t-if="record.exclusive.raw_value"
                                  class="crm-badge crm-badge-exclusive"><i class="fa fa-star me-1"/>Exclusiva</span>
                        </div>

                        <!-- Barra de urgencia -->
                        <div class="crm-kanban-urgency-row" t-if="record.urgency_level.raw_value">
                            <t t-set="lvl" t-value="record.urgency_level.raw_value"/>
                            <span class="crm-urgency-label">Urgencia</span>
                            <div class="crm-urgency-bar">
                                <t t-foreach="[1,2,3,4,5]" t-as="i" t-key="i">
                                    <div t-attf-class="crm-urgency-pip #{ i &lt;= lvl ? 'crm-pip-active crm-pip-level-' + lvl : 'crm-pip-empty' }"/>
                                </t>
                            </div>
                        </div>

                    </div>

                    <footer class="pt-1">
                        <div class="d-flex mt-auto align-items-center">
                            <field name="activity_ids" widget="kanban_activity"/>
                        </div>
                    </footer>
                </t>
            </xpath>

        </field>
    </record>


    <!-- ============================================================
         VISTA LISTA
    ============================================================ -->
    <record id="crm_lead_list_view_custom" model="ir.ui.view">
        <field name="name">crm.lead.list.custom</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_oppor"/>
        <field name="arch" type="xml">

            <!-- Ocultar columnas no necesarias -->
            <field name="expected_revenue" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </field>
            <field name="user_id" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </field>
            <field name="tag_ids" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </field>
            <field name="partner_id" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </field>
            <field name="contact_name" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </field>

            <!-- Añadir columnas personalizadas -->
            <field name="email_from" position="after">
                <field name="budget" string="Presupuesto" optional="show" widget="monetary" options="{'currency_field': 'company_currency'}"/>
                <field name="operation_type" string="Operación" optional="show"/>
                <field name="urgency_level" string="Urgencia" optional="show"/>
                <field name="exclusive" string="Exclusiva" optional="show"/>
            </field>

        </field>
    </record>

</odoo>
